# ─── TradingAgents Configuration ─────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.

# ─── LLM Provider ───────────────────────────────────────────────────────────
# Supported: "openai" (default) or "groq" (free tier available)
LLM_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Groq (optional) — https://console.groq.com/keys
GROQ_API_KEY=

# Model to use (gpt-4o-mini is cheapest; gpt-4o for best quality)
# For Groq: llama-3.3-70b-versatile, mixtral-8x7b-32768, etc.
LLM_MODEL=gpt-4o-mini

# ─── Market Data ────────────────────────────────────────────────────────────
# Finnhub (free tier) — https://finnhub.io/register
FINNHUB_API_KEY=your-finnhub-api-key-here

# ─── Agent Tuning ───────────────────────────────────────────────────────────
# Debate rounds (higher = more thorough analysis, but more API calls)
DEBATE_ROUNDS=2
